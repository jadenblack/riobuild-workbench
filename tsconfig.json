{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": [
      "ES2022"
    ],
    "types": [
      "node",
      "vitest/globals"
    ],
    "outDir": "dist"
  },
  "include": [
    "src",
    "test",
    "vite.config.ts"
  ]
}
